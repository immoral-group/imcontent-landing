# ── Motor Blog ──────────────────────────────────────
# UUID de la vertical en verticales_panel
# Obtener del panel tras registrar la vertical
VERTICAL_ID=

# URL pública del blog en producción
NEXT_PUBLIC_APP_URL=https://imcontent.es

# ── Supabase ─────────────────────────────────────────
# Obtener de Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub Packages ──────────────────────────────────
# Token personal con permisos read:packages
# Mismo mecanismo que en immoralia-landing
NODE_AUTH_TOKEN=

# ── Tracking ─────────────────────────────────────────
# GA4 directo (SPEC-07 v2.0, 14/07/2026) — el ID de medición está
# hardcodeado en app/layout.tsx (G-WR0VBSQ3WF, no es un dato sensible).
# No se usa GTM, esta variable ya no aplica.

# ── Panel ────────────────────────────────────────────
# Token de verificación generado al registrar la vertical
# Obtener del panel junto con VERTICAL_ID
PANEL_OWNERSHIP_TOKEN=
RESEND_API_KEY=

